---
---

<canvas id="scroll-spark" aria-hidden="true"></canvas>

<style>
  #scroll-spark {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 40;
  }
</style>

<script>
  const CHARS = '.:+-=*#@$&~<>[]|/\\';
  const BURST_COUNT = 4;
  const PARTICLE_LIFE = 0.8; // seconds
  const GRAVITY = 30;
  const SCROLL_THROTTLE = 50; // ms between bursts

  type Spark = {
    x: number; y: number;
    vx: number; vy: number;
    char: string;
    life: number;
    maxLife: number;
    size: number;
  };

  let cleanupFn: (() => void) | null = null;

  function init() {
    if (cleanupFn) {
      cleanupFn();
      cleanupFn = null;
    }

    const canvas = document.getElementById('scroll-spark') as HTMLCanvasElement | null;
    if (!canvas) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const ctx = canvas.getContext('2d')!;
    const dpr = Math.min(window.devicePixelRatio || 1, 2);

    let accent = getComputedStyle(document.documentElement)
      .getPropertyValue('--accent').trim();

    const themeObs = new MutationObserver(() => {
      accent = getComputedStyle(document.documentElement)
        .getPropertyValue('--accent').trim();
    });
    themeObs.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['data-theme'],
    });

    function resize() {
      canvas.width = window.innerWidth * dpr;
      canvas.height = window.innerHeight * dpr;
      ctx.scale(dpr, dpr);
    }
    resize();

    const sparks: Spark[] = [];
    let touchX = -1, touchY = -1;
    let lastBurst = 0;
    let animId = 0;
    let running = false;

    function burst(x: number, y: number) {
      for (let i = 0; i < BURST_COUNT; i++) {
        const angle = Math.random() * Math.PI * 2;
        const speed = 40 + Math.random() * 80;
        sparks.push({
          x,
          y,
          vx: Math.cos(angle) * speed,
          vy: Math.sin(angle) * speed - 20, // slight upward bias
          char: CHARS[Math.floor(Math.random() * CHARS.length)],
          life: PARTICLE_LIFE + Math.random() * 0.3,
          maxLife: PARTICLE_LIFE + Math.random() * 0.3,
          size: 8 + Math.random() * 4,
        });
      }
      if (!running) {
        running = true;
        lastFrame = performance.now();
        animId = requestAnimationFrame(frame);
      }
    }

    let lastFrame = 0;

    function frame(now: number) {
      const dt = Math.min((now - lastFrame) / 1000, 0.05);
      lastFrame = now;

      ctx.clearRect(0, 0, window.innerWidth, window.innerHeight);

      let alive = 0;
      for (let i = sparks.length - 1; i >= 0; i--) {
        const s = sparks[i];
        s.life -= dt;
        if (s.life <= 0) {
          sparks.splice(i, 1);
          continue;
        }
        alive++;

        // Physics
        s.vy += GRAVITY * dt;
        s.x += s.vx * dt;
        s.y += s.vy * dt;

        // Friction
        s.vx *= 0.98;
        s.vy *= 0.98;

        // Draw
        const alpha = s.life / s.maxLife;
        ctx.globalAlpha = alpha * alpha; // ease-in fade
        ctx.fillStyle = accent;
        ctx.font = `500 ${s.size}px "IBM Plex Mono", monospace`;
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText(s.char, s.x, s.y);
      }

      ctx.globalAlpha = 1;

      if (alive > 0) {
        animId = requestAnimationFrame(frame);
      } else {
        running = false;
      }
    }

    // Track touch position
    const onTouchStart = (e: TouchEvent) => {
      const t = e.touches[0];
      touchX = t.clientX;
      touchY = t.clientY;
    };
    const onTouchMove = (e: TouchEvent) => {
      const t = e.touches[0];
      touchX = t.clientX;
      touchY = t.clientY;
    };
    const onTouchEnd = () => {
      touchX = -1;
      touchY = -1;
    };

    // Track mouse position
    const onMouseMove = (e: MouseEvent) => {
      touchX = e.clientX;
      touchY = e.clientY;
    };
    const onMouseLeave = () => {
      touchX = -1;
      touchY = -1;
    };

    // Spawn particles on scroll when finger/mouse is tracked
    const onScroll = () => {
      if (touchX < 0) return;
      const now = performance.now();
      if (now - lastBurst < SCROLL_THROTTLE) return;
      lastBurst = now;
      burst(touchX, touchY);
    };

    window.addEventListener('touchstart', onTouchStart, { passive: true });
    window.addEventListener('touchmove', onTouchMove, { passive: true });
    window.addEventListener('touchend', onTouchEnd);
    window.addEventListener('mousemove', onMouseMove, { passive: true });
    document.addEventListener('mouseleave', onMouseLeave);
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', resize);

    // Reset when window loses focus to prevent stale-position sparks
    const clearPos = () => { touchX = -1; touchY = -1; };
    const onVisChange = () => { if (document.hidden) clearPos(); };
    window.addEventListener('blur', clearPos);
    document.addEventListener('visibilitychange', onVisChange);

    cleanupFn = () => {
      cancelAnimationFrame(animId);
      themeObs.disconnect();
      window.removeEventListener('touchstart', onTouchStart);
      window.removeEventListener('touchmove', onTouchMove);
      window.removeEventListener('touchend', onTouchEnd);
      window.removeEventListener('mousemove', onMouseMove);
      document.removeEventListener('mouseleave', onMouseLeave);
      window.removeEventListener('scroll', onScroll);
      window.removeEventListener('resize', resize);
      window.removeEventListener('blur', clearPos);
      document.removeEventListener('visibilitychange', onVisChange);
      sparks.length = 0;
    };
  }

  document.addEventListener('astro:page-load', init);
</script>
