---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const publishedPosts = allPosts
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const allPostsSorted = [...allPosts].sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const recentPublished = publishedPosts.slice(0, 3);

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });

const projects = [
  {
    name: 'vara-wallet',
    desc: 'Agentic CLI wallet for Vara Network. Structured JSON output, encrypted wallets, program interaction.',
    lang: 'Rust',
    url: 'https://github.com/ukint-vs/vara-wallet',
  },
  {
    name: 'vara-skills',
    desc: 'Portable skill pack teaching coding agents the Sails development workflow. 15+ skills from architecture to deployment.',
    lang: 'Skills',
    url: 'https://github.com/ukint-vs/vara-skills',
  },
  {
    name: 'x402-vara',
    desc: 'HTTP-native micropayments with VARA tokens. AI agents pay per-request, no subscriptions.',
    lang: 'TypeScript',
    url: 'https://github.com/ukint-vs/x402-vara',
  },
  {
    name: 'Gear Protocol',
    desc: 'Core contributor. Actor-model smart contracts with async messaging for WebAssembly programs.',
    lang: 'Rust',
    url: 'https://github.com/gear-tech/gear',
  },
  {
    name: 'Awesome Gear',
    desc: 'Curated list of Gear Protocol resources, tools, and applications.',
    lang: 'Community',
    url: 'https://github.com/gear-tech/awesome-gear',
  },
];
---

<BaseLayout title="~/ukint-vs" description="Developer blog by Vadim Smirnov">
  <div class="intro-wrapper">
    <div class="container">
      <section class="intro">
        <div class="intro-text">
          <h1 class="intro-heading">
            devlog~
            <span class="cat-mascot cat-mobile-only">
              <img src="/img/cat-light.webp" alt="Cat mascot" class="cat-light" />
              <img src="/img/cat-dark.webp" alt="Cat mascot" class="cat-dark" />
            </span>
          </h1>
          <p class="intro-bio">
            Software engineer at <a href="https://gear-tech.io">Gear Protocol</a> / <a href="https://vara.network">Vara Network</a>.
            Building AI agent tooling for Web3 — from on-chain wallets to coding skills
            that teach agents how to ship decentralized apps.
          </p>
        </div>
        <div class="cat-mascot cat-desktop-only">
          <img src="/img/cat-light.webp" alt="Cat mascot" class="cat-light" />
          <img src="/img/cat-dark.webp" alt="Cat mascot" class="cat-dark" />
        </div>
      </section>
    </div>
  </div>
  <div class="container">

    <div class="now-block">
      <span class="now-label">What I'm working on</span>
      <p>
        Building <strong>vara-wallet</strong> and <strong>vara-skills</strong> — giving AI agents
        the tools to autonomously interact with the Vara blockchain, from deploying
        programs to managing on-chain assets.
      </p>
    </div>

    <section id="projects">
      <h2 class="section-heading">Projects</h2>
      <ul class="projects-list">
        {projects.map((project) => (
          <li class="project-item">
            <a href={project.url} target="_blank" rel="noopener noreferrer" class="project-link">
              <span class="project-name">{project.name}</span>
              <span class="project-lang">{project.lang}</span>
            </a>
            <p class="project-desc">{project.desc}</p>
          </li>
        ))}
      </ul>
    </section>

    <section id="writing">
      <h2 class="section-heading">Writing</h2>
      <ul class="writing-list">
        {allPostsSorted.map((post) =>
          post.data.draft ? (
            <li>
              <div class="writing-item">
                <span class="writing-title">
                  {post.data.title}
                  <span class="draft-badge">draft</span>
                </span>
                <p class="writing-desc">{post.data.description}</p>
              </div>
            </li>
          ) : (
            <li>
              <a href={`/blog/${post.id}/`} class="writing-item">
                <span class="writing-title">{post.data.title}</span>
                <span class="writing-meta">{formatDate(post.data.date)}</span>
                <p class="writing-desc">{post.data.description}</p>
              </a>
            </li>
          )
        )}
      </ul>
      <a href="/blog/" class="view-all">View all &rarr;</a>
    </section>
  </div>
</BaseLayout>
